{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(terraform fmt *)",
      "Bash(terraform validate *)",
      "Bash(terraform plan *)",
      "Bash(npm test)",
      "Bash(npm run test)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)"
    ],
    "deny": [
      "Bash(curl * | bash *)",
      "Bash(wget * | bash *)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker push *)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy *)",
      "Bash(terraform import *)"
    ],
    "defaultMode": "auto",
    "sandbox": {
      "enabled": true,
      "autoAllowBashIfSandboxed": true,
      "excludedCommands": [
        "git",
        "docker"
      ]
    }
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/claude/hooks/block-destructive-ops.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/block-secret-commit.sh"
          },
          {
            "type": "command",
            "command": "~/.config/claude/hooks/block-destructive-sql.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Pop.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.config/claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "git-actions@cc-plugins": false,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "commit-commands@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "extraKnownMarketplaces": {
    "cc-plugins": {
      "source": {
        "source": "git",
        "url": "https://github.com/biwakonbu/cc-plugins.git"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    }
  },
  "outputStyle": "Explanatory",
  "language": "japanese",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "ﾁﾋﾟﾁﾋﾟ",
      "ﾁｬﾊﾟﾁｬﾊﾟ",
      "ﾄﾞｩﾋﾞﾄﾞｩﾋﾞ",
      "ﾀﾞﾊﾞﾀﾞﾊﾞ",
      "ﾌﾞﾝ ﾌﾞﾝ ﾌﾞﾝ ﾌﾞﾝ"
    ]
  },
  "effortLevel": "xhigh",
  "theme": "dark-ansi",
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true
}
